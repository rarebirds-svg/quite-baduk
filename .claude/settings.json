{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(cd web && npm run *)",
      "Bash(cd web && npm test *)",
      "Bash(cd web && npm install*)",
      "Bash(cd web && npx tsc *)",
      "Bash(cd web && npx vitest*)",
      "Bash(cd web && npx playwright*)",
      "Bash(cd e2e && npm test*)",
      "Bash(cd e2e && npx playwright*)",
      "Bash(cd e2e && npm install*)",
      "Bash(cd e2e && npm run *)",
      "Bash(cd backend && pytest*)",
      "Bash(cd backend && ruff *)",
      "Bash(cd backend && mypy *)",
      "Bash(cd backend && alembic *)",
      "Bash(cd backend && uvicorn *)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git diff*)",
      "Bash(git status*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git restore*)",
      "Bash(git push origin fix/*)",
      "Bash(git push origin feat/*)",
      "Bash(git push origin chore/*)",
      "Bash(git push origin docs/*)",
      "Bash(git push origin test/*)",
      "Bash(git push -u origin fix/*)",
      "Bash(git push -u origin feat/*)",
      "Bash(git push -u origin chore/*)",
      "Bash(git push -u origin docs/*)",
      "Bash(git push -u origin test/*)",
      "Bash(curl -s http://localhost:3000/*)",
      "Bash(curl -s http://localhost:8000/*)",
      "Bash(curl -s -o /dev/null *http://localhost:*)",
      "Bash(lsof -i :*)",
      "Bash(chmod +x *)",
      "Bash(mkdir -p *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push * --force*)",
      "Bash(git push * -f *)",
      "Bash(git push origin master*)",
      "Bash(git push origin HEAD:main*)",
      "Bash(git push origin HEAD:master*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /*)",
      "Bash(npm publish*)",
      "Bash(pip install -g*)",
      "Bash(pip install --system*)",
      "Bash(sudo *)",
      "Write(/Users/daegong/projects/baduk/backend/data/*.db)",
      "Write(/Users/daegong/projects/baduk/backend/katago/models/*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/design-token-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-bell.sh",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
